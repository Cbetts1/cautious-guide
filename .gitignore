# Python cache
__pycache__/
*.py[cod]
*.pyo

# AIOS runtime data lives in ~/.aios/ (outside the repo) — nothing to ignore here.
# If you run AIOS from inside the repo directory and a local .aios/ folder appears,
# uncomment the line below:
# .aios/

# SECURITY NOTE: config/aios.cfg is committed as a template with empty pin_hash/pin_salt.
# After you set a PIN it will contain your hashed credentials. Consider adding
# the line below to prevent accidentally committing your personal config:
# config/aios.cfg

# Virtual environments
venv/
.venv/
env/

# Editor temp files
*.swp
*.swo
*~
.DS_Store
